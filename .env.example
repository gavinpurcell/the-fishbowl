# Required for hosted mode (hides API key config from users)
# NEXT_PUBLIC_HOSTED_MODE=true

# Required: your Anthropic API key (server-side, or users provide their own)
# ANTHROPIC_API_KEY=sk-ant-...

# Upstash Redis — enables rate limiting, spend cap, and lead capture
# If unset, these features are disabled (fine for self-hosting)
# REDIS_URL=https://...upstash.io
# UPSTASH_REDIS_REST_URL=https://...upstash.io
# UPSTASH_REDIS_REST_TOKEN=...

# Daily spend cap in USD (default: 100). New sessions blocked when exceeded.
# DAILY_SPEND_CAP=100

# Max sessions per IP per day (default: 3)
# DAILY_SESSION_LIMIT=3
